# Auto detect text files and perform LF normalization
* text=auto

# Define binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.mov binary
*.mp4 binary
*.zip binary
*.gz binary

# Force Unix line endings for scripts
*.sh text eol=lf
*.php text eol=lf
*.js text eol=lf
*.json text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.xml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Exclude from export
/.github export-ignore
/.vscode export-ignore
/tests export-ignore
/storage export-ignore
/node_modules export-ignore
/vendor export-ignore
*.md export-ignore
.gitattributes export-ignore
.gitignore export-ignore
composer.lock export-ignore
package-lock.json export-ignore
phpunit.xml export-ignore
vite.config.js export-ignore
tailwind.config.js export-ignore
