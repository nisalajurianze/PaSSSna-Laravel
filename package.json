{
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "watch": "vite build --watch",
        "prod": "npm run production",
        "production": "vite build",
        "serve": "vite preview",
        "css:dev": "npx tailwindcss -i ./resources/css/app.css -o ./public/css/app.css --watch",
        "css:prod": "npx tailwindcss -i ./resources/css/app.css -o ./public/css/app.css --minify",
        "dev:all": "concurrently \"npm run dev\" \"npm run css:dev\"",
        "build:all": "npm run css:prod && npm run build"
    },
    "devDependencies": {
        "@alpinejs/focus": "^3.12.3",
        "@alpinejs/persist": "^3.12.3",
        "@tailwindcss/aspect-ratio": "^0.4.2",
        "@tailwindcss/forms": "^0.5.7",
        "@tailwindcss/typography": "^0.5.10",
        "@vitejs/plugin-vue": "^4.2.3",
        "alpinejs": "^3.12.3",
        "autoprefixer": "^10.4.15",
        "axios": "^1.5.0",
        "chart.js": "^4.4.0",
        "concurrently": "^8.2.1",
        "laravel-vite-plugin": "^0.8.0",
        "lodash": "^4.17.21",
        "moment": "^2.29.4",
        "postcss": "^8.4.29",
        "sass": "^1.66.1",
        "sweetalert2": "^11.7.27",
        "tailwindcss": "^3.3.3",
        "vite": "^4.4.9",
        "vue": "^3.3.4"
    },
    "dependencies": {
        "@fortawesome/fontawesome-free": "^6.4.2",
        "animate.css": "^4.1.1",
        "aos": "^2.3.4",
        "dropzone": "^6.0.0-beta.2",
        "fullcalendar": "^6.1.9",
        "inputmask": "^5.0.8",
        "print-js": "^1.6.0",
        "quill": "^1.3.7",
        "select2": "^4.1.0-rc.0",
        "sortablejs": "^1.15.0"
    }
}
